# Domain Expert Multi-Agent System Configuration
# Copy this file to .env and configure for your deployment

# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: Custom base URL for Anthropic-compatible APIs (e.g., DashScope)
# ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
# Optional: Custom model name (overrides DEFAULT_LLM_MODEL)
# ANTHROPIC_MODEL=kimi-k2.5
OPENAI_API_KEY=your_openai_api_key_here

# Database
# For Docker deployment: postgresql://postgres:postgres@postgres:5432/domain_expert
# For local development: postgresql://postgres:postgres@localhost:5432/domain_expert
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/domain_expert

# Redis
# For Docker deployment: redis://redis:6379/0
# For local development: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Vector Store
VECTOR_DB_PATH=./data/chromadb

# File Upload
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=104857600

# Security - IMPORTANT: Change this to a strong random string for production!
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-strong-secret-key-for-production

# CORS - Comma-separated list of allowed origins
# For public deployment, include your server IP:
# ALLOWED_ORIGINS=http://47.115.58.203,http://localhost:5173,http://localhost:3000
# For local development only:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# Optional: Neo4j for knowledge graph
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# Optional: Semantic Scholar API Key
# Increases rate limit from 1 req/s to 10 req/s for citation enrichment
# Apply at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your_key_here
SEMANTIC_SCHOLAR_NETWORK_LIMIT=100  # max corpus size for fetching citation network
